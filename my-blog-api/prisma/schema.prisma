generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Article {
  id          String  @id @default(uuid())
  title       String
  description String
  poster      String? // untuk nampung URL dari cloudinary

  isPublished Boolean   @default(false) // untuk memberi tanda apakah artikel sudah dikirim oleh scheduler atau belum
  publishedAt DateTime? // untuk memberi tanda kapan artikel dikirim

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      Role      @default(GUEST)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

enum Role {
  GUEST
  VIP
}

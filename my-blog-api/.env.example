# Database Configuration (Supabase with Connection Pooling)
DATABASE_URL="postgresql://<DB_USER>:<DB_PASSWORD>@<DB_HOST>:<DB_PORT>/<DB_NAME>?pgbouncer=true"

# Server Configuration
PORT=8000
JWT_SECRET=your_jwt_secret_key_here

# Cloudinary Credentials (Media Storage)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# Email Configuration (SMTP / Nodemailer)
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password

# Upstash Redis Configuration (Caching / Rate Limiting)
UPSTASH_REDIS_REST_URL="https://<YOUR_REDIS_HOST>.upstash.io"
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token
UPSTASH_REDIS_URL="redis://default:<YOUR_REDIS_PASSWORD>@<YOUR_REDIS_HOST>.upstash.io:6379"